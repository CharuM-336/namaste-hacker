{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "module": "NodeNext",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@namaste-hacker/ui/*": ["src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "nodenext"
  },
  "include": ["src"]
}
